# Transitland API configuration for proxy system (Nuxt 3 runtime config)
TRANSITLAND_API_BASE="https://api.transit.land/api/v2" # cli
NUXT_TLV2_PROXY_BASE_DEFAULT="https://api.transit.land/api/v2"

# Map tiles
NUXT_PUBLIC_TLV2_PROTOMAPS_APIKEY=$PROTOMAPS_APIKEY

# Login gate (set to true to test production auth behavior)
NUXT_PUBLIC_TLV2_LOGIN_GATE=false
NUXT_PUBLIC_TLV2_REQUIRE_LOGIN=false

# Auth0 server-side sessions (via @interline-io/tlv2-auth)
# Only needed when loginGate/requireLogin are enabled
# NUXT_AUTH0_DOMAIN=interline.us.auth0.com
# NUXT_AUTH0_CLIENT_ID=
# NUXT_AUTH0_CLIENT_SECRET=
# NUXT_AUTH0_SESSION_SECRET=  # random 32+ byte hex string; ephemeral one generated if omitted
# NUXT_AUTH0_APP_BASE_URL=http://localhost:3000
# NUXT_AUTH0_AUDIENCE=https://api.transit.land

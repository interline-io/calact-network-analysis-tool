    "test:watch": "vitest --watch",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@aitodotai/json-stringify-pretty-compact": "1.3.0",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/eslint-config": "1.10.0",
    "@turf/bbox": "7.2.0",
    "@types/big-json": "3.2.0",
    "@types/node": "latest",
    "big-json": "3.2.0",
    "csv-stringify": "6.6.0",
    "d3-scale": "4.0.2",
    "d3-scale-chromatic": "3.1.0",
    "eslint": "9.39.1",
    "nuxt": "4.2.0",
    "sass-embedded": "1.93.3",
    "@interline-io/tlv2-ui": "github:interline-io/tlv2-ui#38917558d6fdc15710b38dcae736fd18f3502f19",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.3",
    "vitest": "3.2.4",
    "vue": "3.5.22",
    "vue-tsc": "3.1.1"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/d3-scale": "4.0.9",
    "@types/d3-scale-chromatic": "3.1.0",
    "@vitest/coverage-v8": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver",
